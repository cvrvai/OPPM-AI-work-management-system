# Root-level environment example — copy to apps/.env and fill in values
# See apps/.env.example for full reference

# ── Database ──
DATABASE_URL=postgresql+asyncpg://oppm:oppm_secret@localhost:5432/oppm

# ── Redis ──
REDIS_URL=redis://:oppm_redis_secret@localhost:6379/0

# ── JWT ──
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Service auth ──
INTERNAL_API_KEY=generate-a-strong-random-key-here

# ── CORS ──
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Environment ──
ENVIRONMENT=development

# ── AI Providers ──
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
KIMI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# ── Git service ──
AI_SERVICE_URL=http://localhost:8001
